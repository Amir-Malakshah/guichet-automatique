<Window x:Class="guichet_automatique.createClient"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:guichet_automatique"
        mc:Ignorable="d"
        Title="createClient" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Code:" VerticalAlignment="Center"/>
        <TextBox x:Name="CodeTextBox" Grid.Row="0" Margin="100,0" Width="200"/>
        
        
        <TextBlock Grid.Row="1" Text="Prenom:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtPrenom" Grid.Row="1" Margin="100,0" Width="200"/>

        <TextBlock Grid.Row="2" Text="Nom:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtNom" Grid.Row="2" Margin="100,0" Width="200"/>

        <TextBlock Grid.Row="3" Text="Adresse:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtAdresse" Grid.Row="3" Margin="100,0" Width="200"/>

        <TextBlock Grid.Row="4" Text="Telephone:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtTelephone" Grid.Row="4" Margin="100,0" Width="200"/>

        <TextBlock Grid.Row="5" Text="NIP:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtNip" Grid.Row="5" Margin="100,0" Width="200"/>

        <Button x:Name="btnEnregistrer"  Grid.Row="6" Content="Enregistrer" Width="100" Height="30" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,10" Click="EnregistrerButton_Click"/>
    </Grid>
</Window>
