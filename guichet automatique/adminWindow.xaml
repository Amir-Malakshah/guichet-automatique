<Window x:Class="guichet_automatique.adminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:guichet_automatique"
        mc:Ignorable="d"
        Title="adminWindow" Height="600" Width="800">
    <Grid>
        
        <Menu VerticalAlignment="Top">
            <MenuItem Header="Client" >
                <MenuItem Header="Créer un client" Click="CreateClient_Click"/>
            </MenuItem>
            <MenuItem Header="Compte">
                <MenuItem Header="Créer un compte" Click="CreateAccount_Click"/>
            </MenuItem>
            <MenuItem Header="Transactions">
                <MenuItem Header="Afficher toutes les transactions" Click="ViewTransactions_Click"/>
            </MenuItem>
            <MenuItem Header="Guichet">
                <MenuItem Header="Ajouter de l'argent au guichet" Click="AddMoneyToATM_Click"/>
                <MenuItem Header="Fermer le guichet" Click="CloseATM_Click"/>
            </MenuItem>
            <MenuItem Header="Actions supplémentaires">
                <MenuItem Header="Payer des intérêts" Click="PayInterest_Click"/>
                <MenuItem Header="Augmenter les marges de crédit" Click="IncreaseCreditLimit_Click"/>
                <MenuItem Header="prélever un montant d'un compte hypothécaire" Click="btnPrelever_Click"/>
                <MenuItem Header="Bloquer ou débloquer l'accès à un client" Click="btnAcces_Click"/>
            </MenuItem>
            
        </Menu>

        
        <TabControl HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,40,0,0">
            <TabItem Header="Comptes">
                <DataGrid Name="accountsDataGrid" AutoGenerateColumns="True" IsReadOnly="True" ItemBindingGroup="{Binding}" />
            </TabItem>
            <TabItem Header="Transactions">
                <DataGrid Name="transactionsDataGrid" AutoGenerateColumns="True" IsReadOnly="True" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
