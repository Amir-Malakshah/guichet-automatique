<Window x:Class="guichet_automatique.SuiviClientUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:guichet_automatique"
        mc:Ignorable="d"
        Title="SuiviClientUI" Height="450" Width="800">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Fichier">
                <MenuItem Header="_Quitter" Click="mnuQuitter_Click" />
            </MenuItem>
            <MenuItem Header="_Pay and Transfer">
                <MenuItem Header="_WITHIN CANADA" Click="mnuTransfer_Click" />
            </MenuItem>
        </Menu>
    <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
        
        <DataGrid Grid.Row="1"  Name="DataGridComptes" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" AutoGenerateColumns="True"/>
    </Grid>
        
    </DockPanel>
    
</Window>
