<Window x:Class="guichet_automatique.Bills"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:guichet_automatique"
        mc:Ignorable="d"
             Title="Pay Bills" Height="300" Width="400">
    <Grid>
        <StackPanel>
            <TextBlock Text="Sélectionner le compte" Margin="10"/>
            <ComboBox x:Name="CompteComboBox"  Margin="10" ItemsSource="{Binding}" DisplayMemberPath="Type" SelectedValuePath="Id"/>

            <TextBlock Text="Montant" Margin="10"/>
            <TextBox x:Name="MontantTextBox" Margin="10"/>

            <TextBlock Text="Facture" Margin="10"/>
            <TextBox x:Name="FactureTextBox" Margin="10"/>

            <Button Content="Payer" HorizontalAlignment="Center" Margin="10" Click="PayerButton_Click"/>
        </StackPanel>
        <Button Content="Retour à l'accueil" VerticalAlignment="Bottom" HorizontalAlignment="Right" Click="RetourAccueil_Click"/>
    </Grid>
</Window>
